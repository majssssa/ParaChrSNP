rule merge_sample_gvcf:
    input:
        "gvcf/{sample}.list"
    output:
        "gvcf/{sample}.g.vcf.gz"
    log:
        "logs/gatk/merge_sample_gvcf/{sample}.log"
    shell:
        "gatk MergeVcfs -I {input} -O {output} > {log} 2>&1"
