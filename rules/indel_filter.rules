rule indel_filter:
    input:
        vcf="result_vcfs/combined.indel.vcf.gz",
        ref=config['reference']
    output:
        vcf="result_vcfs/combined.indel.filtered.vcf.gz"
    log:
        "logs/gatk/filter/indel.log"
    params:
        filters=config["params"]["indel_filter"]["filter_name"],
        expression=(
            "QD < {qd} || FS > {fs} || SOR > {sor} || "
            "MQRankSum < {mq_rank_sum} || ReadPosRankSum < {read_pos_rank_sum}"
        ).format(**config["params"]["indel_filter"]["thresholds"])
    shell:
        """
        tmp_prefix=$(mktemp -u result_vcfs/combined.indel.marked.tmp.XXXXXX)
        marked_vcf="$tmp_prefix.vcf.gz"
        trap 'rm -f "$marked_vcf" "$marked_vcf.tbi" "$marked_vcf.idx"' EXIT

        gatk VariantFiltration \
            -R {input.ref} \
            -V {input.vcf} \
            --filter-expression "{params.expression}" \
            --filter-name "{params.filters}" \
            -O "$marked_vcf" \
            > {log} 2>&1

        gatk SelectVariants \
            -R {input.ref} \
            -V "$marked_vcf" \
            --exclude-filtered \
            -O {output.vcf} \
            >> {log} 2>&1

        rm -f "$marked_vcf" "$marked_vcf.tbi"
        """
