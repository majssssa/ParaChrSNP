rule bwa_index:
    input:
        ref=config['reference'],
        precheck=ancient("reports/precheck.done")
    output:
        idx0123=config['reference'] + ".0123",
        amb=config['reference'] + ".amb",
        ann=config['reference'] + ".ann",
        bwt=config['reference'] + ".bwt.2bit.64",
        pac=config['reference'] + ".pac"
    params:
        executable=config["params"].get("bwa", {}).get("executable", "bwa-mem2")
    log:
        "logs/index/bwa_index.log"
    shell:
        "{params.executable} index {input.ref} > {log} 2>&1"
