rule vcf2pca:
    input:
        vcf="result_vcfs/combined.snp.filtered.vcf.gz",
        sample_group=lambda wildcards: [config["params"]["vcf2pca"].get("sample_group")] if config["params"]["vcf2pca"].get("sample_group") else []
    output:
        eigenvec=config["params"]["vcf2pca"]["output_prefix"] + ".eigenvec",
        eigenval=config["params"]["vcf2pca"]["output_prefix"] + ".eigenval",
        plot2_c_svg=config["params"]["vcf2pca"].get("plot_prefix", config["params"]["vcf2pca"]["output_prefix"] + ".plot") + ".C.PC1_PC2.p.svg",
        plot2_n_svg=config["params"]["vcf2pca"].get("plot_prefix", config["params"]["vcf2pca"]["output_prefix"] + ".plot") + ".N.PC1_PC2.p.svg",
        plot3_c_pdf=config["params"]["vcf2pca"].get("plot_prefix", config["params"]["vcf2pca"]["output_prefix"] + ".plot") + ".C.3DPC1PC2PC3.pdf",
        plot3_n_pdf=config["params"]["vcf2pca"].get("plot_prefix", config["params"]["vcf2pca"]["output_prefix"] + ".plot") + ".N.3DPC1PC2PC3.pdf"
    params:
        executable=config["params"]["vcf2pca"]["executable"],
        output_prefix=config["params"]["vcf2pca"]["output_prefix"],
        plot_prefix=config["params"]["vcf2pca"].get("plot_prefix", config["params"]["vcf2pca"]["output_prefix"] + ".plot"),
        plot2_executable=config["params"]["vcf2pca"].get("plot2_executable", "Plot2Deig"),
        plot3_executable=config["params"]["vcf2pca"].get("plot3_executable", "Plot3Deig"),
        extra=config["params"]["vcf2pca"].get("extra", ""),
        sample_count=len(config["samples"]),
        sample_group_arg=lambda wildcards, input: f"-InSampleGroup {input.sample_group}" if input.sample_group else ""
    threads:
        config["params"]["vcf2pca"]["threads"]
    log:
        "logs/vcf2pca/vcf2pca.log"
    shell:
        """
        mkdir -p $(dirname {params.output_prefix})

        if [ {params.sample_count} -lt 3 ]; then
            echo "VCF2PCACluster requires at least 3 samples, but config.yaml contains {params.sample_count} sample(s)." > {log}
            echo "Set params.vcf2pca.enabled: false for small test datasets, or provide at least 3 samples." >> {log}
            exit 1
        fi

        {params.executable} \
            -InVCF {input.vcf} \
            -OutPut {params.output_prefix} \
            {params.sample_group_arg} \
            -Threads {threads} \
            {params.extra} \
            > {log} 2>&1

        {params.plot2_executable} \
            -InFile {output.eigenvec} \
            -OutPut {params.plot_prefix} \
            >> {log} 2>&1

        {params.plot3_executable} \
            -InFile {output.eigenvec} \
            -OutPut {params.plot_prefix} \
            >> {log} 2>&1
        """
